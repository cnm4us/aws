# Jaeger/OTel local profile for `npm run serve:jaeger`

OTEL_ENABLED=1
# App -> OTel Collector (Phase D)
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:5318
OTEL_SERVICE_NAME=aws-mediaconvert-service
OTEL_SERVICE_VERSION=dev

LOG_LEVEL=debug
LOG_FORMAT=pretty

# Noise controls
OTEL_INSTRUMENT_MYSQL2=0
OTEL_INSTRUMENT_EXPRESS=0
OTEL_INSTRUMENT_NET=0
OTEL_TRACE_STATIC=0
OTEL_TRACE_PROBES=0
OTEL_TRACE_ROOT=0
LOG_REQUEST_STATIC=0
LOG_REQUEST_PROBES=0
LOG_REQUEST_ROOT=0

# Optional analytics sink profile (disabled by default in local Jaeger profile)
ANALYTICS_SINK_ENABLED=0
ANALYTICS_SINK_PROVIDER=none
ANALYTICS_SINK_SAMPLE_RATE=1
ANALYTICS_SINK_TIMEOUT_MS=2000
# ANALYTICS_SINK_POSTHOG_HOST=https://app.posthog.com
# ANALYTICS_SINK_POSTHOG_API_KEY=

# Message pacing (global; used by message decision service)
# MESSAGE_MAX_MESSAGES_PER_SESSION=2
# MESSAGE_MIN_SLIDES_BEFORE_FIRST_MESSAGE=6
# MESSAGE_MIN_WATCH_SECONDS_BEFORE_FIRST_MESSAGE=45
# MESSAGE_MIN_SLIDES_BETWEEN_MESSAGES=15
# MESSAGE_COOLDOWN_SECONDS_AFTER_MESSAGE=900
# MESSAGE_PASS_THROUGH_MIN_VISIBLE_MS=800
# MESSAGE_DEBUG=1
# ANON_SESSION_SLIDING=1
