{
  "name": "aws-mediaconvert-service",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p .",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "serve": "ts-node-dev --respawn --exit-child --transpile-only --ignore-watch public,frontend src/server.ts",
    "serve:jaeger": "bash scripts/serve-jaeger.sh",
    "serve:jaeger:log": "bash scripts/serve-jaeger-log.sh",
    "start": "node dist/index.js",
    "mc:describe": "ts-node src/tools/mediaconvert/describe-endpoints.ts",
    "mc:create": "ts-node src/tools/mediaconvert/create-job.ts",
    "test:naming": "ts-node scripts/test-naming.ts",
    "check:agents:docs": "python3 scripts/check-agent-docs.py",
    "check:console:backend": "node scripts/check-backend-console.js",
    "jaeger:start": "bash scripts/jaeger.sh start",
    "jaeger:stop": "bash scripts/jaeger.sh stop",
    "jaeger:status": "bash scripts/jaeger.sh status",
    "jaeger:logs": "tail -n 120 logs/jaeger.log",
    "jaeger:query": "bash scripts/jaeger-query.sh",
    "debug:bundle": "bash scripts/debug-bundle.sh",
    "prometheus:start": "bash scripts/prometheus.sh start",
    "prometheus:stop": "bash scripts/prometheus.sh stop",
    "prometheus:status": "bash scripts/prometheus.sh status",
    "prometheus:logs": "tail -n 120 logs/prometheus.log",
    "otelcol:start": "bash scripts/otelcol.sh start",
    "otelcol:stop": "bash scripts/otelcol.sh stop",
    "otelcol:status": "bash scripts/otelcol.sh status",
    "otelcol:logs": "tail -n 120 logs/otelcol.log",
    "obs:start": "bash scripts/observability-stack.sh start",
    "obs:stop": "bash scripts/observability-stack.sh stop",
    "obs:status": "bash scripts/observability-stack.sh status",
    "obs:logs": "bash scripts/observability-stack.sh logs",
    "web:clean": "node scripts/clean-web.js",
    "web:build": "npm run build && npm run web:clean && vite build --config frontend/vite.config.ts",
    "web:bundle-snapshot": "node scripts/report-web-bundles.js --append",
    "space:web:clean": "node scripts/clean-space-web.js",
    "space:web:build": "npm run build && npm run space:web:clean && vite build --config frontend/vite.space.config.ts",
    "port-clear": "node scripts/port-clear.js",
    "web:deploy": "node scripts/web-deploy.js root",
    "web:build:scoped": "npm run build && vite build --config frontend/vite.config.ts",
    "web:deploy:scoped": "node scripts/web-deploy.js scoped",
    "admin:own-uploads": "ts-node scripts/admin-own-uploads.ts",
    "admin:backfill-rule-drafts": "ts-node scripts/backfill-rule-drafts.ts",
    "admin:backfill-spaces-ulid": "ts-node scripts/backfill-spaces-ulid.ts",
    "admin:backfill-audio-durations": "ts-node scripts/backfill-audio-durations.ts",
    "admin:seed-message-test-audiences": "ts-node scripts/seed-message-test-audiences.ts",
    "admin:backfill-image-derivatives": "ts-node scripts/backfill-upload-image-derivatives.ts",
    "admin:backfill-image-derivatives:loop": "bash scripts/backfill-upload-image-derivatives-loop.sh",
    "db:clear:suppression": "ts-node scripts/db-clear-suppression.ts",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:headed": "cross-env HEADLESS=false playwright test --config=e2e/playwright.config.ts",
    "e2e:ui": "cross-env HEADLESS=false playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:install": "playwright install --with-deps",
    "payments:smoke": "bash scripts/smoke-payments.sh",
    "db:query:donations": "ts-node scripts/db-query-donations.ts",
    "db:query:subscriptions": "ts-node scripts/db-query-subscriptions.ts",
    "db:backfill:donation-amounts": "ts-node scripts/db-backfill-donation-amounts.ts",
    "payments:diagnose:subscribe-plans": "ts-node scripts/payments-diagnose-subscribe-plans.ts",
    "payments:reconcile": "ts-node scripts/payments-reconcile.ts",
    "payments:paypal:create-plans": "ts-node scripts/payments-paypal-create-plans.ts"
  },
  "dependencies": {
    "@aws-sdk/client-mediaconvert": "^3.645.0",
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/credential-providers": "^3.645.0",
    "@aws-sdk/s3-presigned-post": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.964.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "@xmldom/xmldom": "^0.8.11",
    "bowser": "^2.12.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "hls.js": "^1.6.13",
    "mysql2": "^3.11.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-intersection-observer": "^9.16.0",
    "yargs": "^17.7.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/yargs": "^17.0.33",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "workbox-build": "^7.3.0"
  }
}
